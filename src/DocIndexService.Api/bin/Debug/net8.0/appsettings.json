{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=docindexservice;Username=postgres;Password=postgres",
    "MigrationsAssembly": "DocIndexService.Infrastructure"
  },
  "Tika": {
    "BaseUrl": "http://localhost:9998",
    "TimeoutSeconds": 30
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "EmbeddingModel": "nomic-embed-text"
  },
  "Scanning": {
    "IncrementalIntervalMinutes": 15,
    "FullReconciliationHourUtc": 2,
    "MaxFileSizeMb": 50
  },
  "AllowedHosts": "*"
}
