<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DocIndexService.Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DocIndexService.Admin.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid px-3 px-md-4">
                <a class="navbar-brand" asp-area="" asp-page="/Dashboard/Index">DocIndexService Admin</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link" asp-page="/Dashboard/Index">Dashboard</a></li>
                            @if (User.IsInRole("SystemAdmin") || User.IsInRole("IndexManager"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-page="/Sources/Index">Sources</a></li>
                            }
                            <li class="nav-item"><a class="nav-link" asp-page="/Documents/Index">Documents</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Jobs/Index">Jobs</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Audit/Index">Audit Log</a></li>
                            @if (User.IsInRole("SystemAdmin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-page="/Users/Index">Users</a></li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted small">@User.Identity?.Name</span>
                            <form method="post" asp-page="/Account/Logout">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Sign Out</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item"><a class="nav-link" asp-page="/Account/Login">Sign In</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-3 px-md-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid px-3 px-md-4">
            &copy; 2026 - DocIndexService.Admin
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>