@page
@model DocIndexService.Admin.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documents";
}

<h1 class="h4 mb-3">Documents</h1>
<p class="text-muted">Document listing and detail workflow shell.</p>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm mb-0">
                <thead>
                    <tr><th>File</th><th>Status</th><th>Updated</th><th></th></tr>
                </thead>
                <tbody>
                    <tr><td class="text-muted" colspan="4">No records yet.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="alert alert-secondary mt-3 mb-0">
    Details route is available at <code>/Documents/Details/{id}</code> once document query wiring is added.
</div>
