@page
@model DocIndexService.Admin.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 mb-3">Admin Sign In</h1>
                <p class="text-muted mb-4">Use your local DocIndexService administrator credentials.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.UserNameOrEmail" class="form-label"></label>
                        <input asp-for="Input.UserNameOrEmail" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Input.UserNameOrEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Sign In</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
