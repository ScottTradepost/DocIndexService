@page
@model DocIndexService.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<h1 class="h4 mb-3">Users</h1>
<p class="text-muted">Create and review local users and role assignments.</p>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div class="fw-semibold">Unable to save user:</div>
        <ul class="mb-0">
            @foreach (var value in ViewContext.ModelState.Values)
            {
                foreach (var error in value.Errors)
                {
                    <li>@error.ErrorMessage</li>
                }
            }
        </ul>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h6 mb-3">Add User</h2>
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-3">
                <input asp-for="NewUser.UserName" class="form-control form-control-sm" placeholder="Username" />
            </div>
            <div class="col-md-3">
                <input asp-for="NewUser.Email" class="form-control form-control-sm" placeholder="Email" />
            </div>
            <div class="col-md-3">
                <input asp-for="NewUser.Password" class="form-control form-control-sm" placeholder="Password" />
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check">
                    <input asp-for="NewUser.IsEnabled" class="form-check-input" />
                    <label asp-for="NewUser.IsEnabled" class="form-check-label">Enabled</label>
                </div>
            </div>

            <div class="col-12">
                <div class="small fw-semibold mb-1">Roles</div>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var role in Model.Roles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="NewUser.SelectedRoleNames" value="@role.Name" id="role_@role.Name" />
                            <label class="form-check-label" for="role_@role.Name">
                                @role.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary btn-sm">Create User</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Existing Users</div>
    <div class="table-responsive">
        <table class="table table-sm mb-0">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Roles</th>
                    <th>Last Login (UTC)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Users.Count > 0)
            {
                foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge @(user.IsEnabled ? "bg-success" : "bg-danger")">
                                @(user.IsEnabled ? "Enabled" : "Disabled")
                            </span>
                        </td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td>@(user.LastLoginUtc?.ToString("u") ?? "n/a")</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                @if (user.IsEnabled)
                                {
                                    <form method="post" asp-page-handler="SetEnabled" style="display: inline;">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="isEnabled" value="false" />
                                        <button type="submit" class="btn btn-warning btn-sm" title="Disable user">Disable</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="SetEnabled" style="display: inline;">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="isEnabled" value="true" />
                                        <button type="submit" class="btn btn-success btn-sm" title="Enable user">Enable</button>
                                    </form>
                                }
                                <button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#resetPasswordModal_@user.Id" title="Reset password">Reset Pass</button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-muted">No users found.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Password Reset Modals -->
@foreach (var user in Model.Users)
{
    <div class="modal fade" id="resetPasswordModal_@user.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reset Password for @user.UserName</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="ResetPassword">
                    <div class="modal-body">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="mb-3">
                            <label for="newPassword_@user.Id" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="newPassword_@user.Id" name="newPassword" placeholder="New password (min 8 characters)" required minlength="8" />
                            <small class="form-text text-muted">Must be at least 8 characters</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Reset Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
